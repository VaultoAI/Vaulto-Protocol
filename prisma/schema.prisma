// Prisma schema for Vaulto Protocol - Reg S Compliant Onboarding

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum OnboardingStatus {
  NOT_STARTED
  GEO_CHECK_PENDING
  GEO_CHECK_PASSED
  GEO_BLOCKED
  KYC_PENDING
  KYC_IN_REVIEW
  KYC_APPROVED
  KYC_REJECTED
  WALLET_PENDING
  WALLET_APPROVED
  WALLET_REJECTED
  SOURCE_OF_FUNDS_PENDING
  SOURCE_OF_FUNDS_APPROVED
  RISK_ACKNOWLEDGMENT_PENDING
  COMPLIANCE_PERIOD_ACTIVE
  FULLY_ONBOARDED
  SUSPENDED
}

enum KycStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum WalletVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  HIGH_RISK
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  SEVERE
}

enum AuditAction {
  GEO_CHECK_INITIATED
  GEO_CHECK_PASSED
  GEO_CHECK_BLOCKED
  KYC_INITIATED
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  KYC_EXPIRED
  WALLET_CONNECTED
  WALLET_VERIFIED
  WALLET_REJECTED
  SOURCE_OF_FUNDS_SUBMITTED
  SOURCE_OF_FUNDS_APPROVED
  RISK_ACKNOWLEDGMENT_SIGNED
  COMPLIANCE_PERIOD_STARTED
  COMPLIANCE_PERIOD_COMPLETED
  ONBOARDING_COMPLETED
  USER_SUSPENDED
  USER_REINSTATED
  // Trading wallet actions
  TRADING_WALLET_CREATED
  TRADING_WALLET_DEPOSIT_INITIATED
  TRADING_WALLET_DEPOSIT_CONFIRMED
  TRADING_WALLET_DEPOSIT_DETECTED
  TRADING_WALLET_WITHDRAWAL_REQUESTED
  TRADING_WALLET_WITHDRAWAL_APPROVED
  TRADING_WALLET_WITHDRAWAL_EXECUTED
  TRADING_WALLET_WITHDRAWAL_REJECTED
  TRADING_WALLET_WITHDRAWAL_RECOVERED
  // ETF trading actions
  ETF_ORDER_PLACED
  ETF_ORDER_FILLED
  ETF_ORDER_CANCELED
  ETF_ORDER_REJECTED
}

enum TradingWalletStatus {
  PENDING_CREATION
  ACTIVE
  SUSPENDED
}

enum DepositStatus {
  PENDING
  CONFIRMING
  COMPLETED
  FAILED
}

enum WithdrawalStatus {
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

enum EtfOrderStatus {
  PENDING
  SUBMITTED
  PARTIALLY_FILLED
  FILLED
  CANCELED
  REJECTED
  EXPIRED
}

enum UserTier {
  STANDARD
  VERIFIED
  INSTITUTIONAL
}

// ============================================
// MODELS
// ============================================

model User {
  id                    String              @id @default(cuid())
  email                 String              @unique
  name                  String?
  image                 String?
  onboardingStatus      OnboardingStatus    @default(NOT_STARTED)
  isVaultoEmployee      Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // Waitlist leaderboard fields
  bonusPoints           Int                 @default(0)
  hasSharedToX          Boolean             @default(false)
  sharedToXAt           DateTime?

  // Referral system
  referralCode          String?             @unique
  referredById          String?
  referredBy            User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referrals             User[]              @relation("UserReferrals")

  // Relations
  geoVerifications      GeoVerification[]
  kycVerification       KycVerification?
  walletVerifications   WalletVerification[]
  sourceOfFundsDeclaration SourceOfFundsDeclaration?
  riskAcknowledgment    RiskAcknowledgment?
  compliancePeriod      CompliancePeriod?
  auditLogs             AuditLog[]
  tradingWallet         TradingWallet?

  // User tier for withdrawal limits
  tier                  UserTier            @default(STANDARD)

  @@index([email])
  @@index([onboardingStatus])
  @@index([createdAt])
  @@index([referralCode])
}

model GeoVerification {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  ipAddress         String
  countryCode       String
  countryName       String
  city              String?
  region            String?
  isVpnDetected     Boolean   @default(false)
  isProxyDetected   Boolean   @default(false)
  isTorDetected     Boolean   @default(false)
  isBlocked         Boolean   @default(false)
  blockReason       String?

  // User declaration
  declaredNonUs     Boolean   @default(false)
  declaredCountry   String?
  declarationSignedAt DateTime?

  verifiedAt        DateTime  @default(now())

  // MaxMind response data (encrypted at rest in production)
  rawResponseHash   String?

  @@index([userId])
  @@index([countryCode])
  @@index([isBlocked])
}

model KycVerification {
  id                String      @id @default(cuid())
  userId            String      @unique
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Sumsub data
  sumsubApplicantId String?     @unique
  sumsubAccessToken String?     // Short-lived token for WebSDK
  tokenExpiresAt    DateTime?

  status            KycStatus   @default(PENDING)
  reviewResult      String?     // JSON string with review details

  // Document verification results (encrypted)
  documentType      String?
  documentCountry   String?
  documentVerified  Boolean     @default(false)

  // Liveness check
  livenessVerified  Boolean     @default(false)

  // AML screening
  amlScreeningPassed Boolean    @default(false)
  amlRiskLevel      RiskLevel?

  // Timestamps
  initiatedAt       DateTime    @default(now())
  submittedAt       DateTime?
  reviewedAt        DateTime?
  expiresAt         DateTime?

  @@index([sumsubApplicantId])
  @@index([status])
}

model WalletVerification {
  id                String                   @id @default(cuid())
  userId            String
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  walletAddress     String
  chainId           Int

  // Ownership verification
  signatureMessage  String?
  signatureHash     String?
  ownershipVerified Boolean                  @default(false)
  ownershipVerifiedAt DateTime?

  // Chainalysis screening
  status            WalletVerificationStatus @default(PENDING)
  riskLevel         RiskLevel?
  screeningScore    Float?

  // Screening flags
  isSanctioned      Boolean                  @default(false)
  isHighRisk        Boolean                  @default(false)
  riskCategories    String[]                 // Array of risk categories

  screenedAt        DateTime?
  screeningExpires  DateTime?

  // Raw Chainalysis response hash
  rawResponseHash   String?

  isPrimary         Boolean                  @default(false)

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([userId, walletAddress])
  @@index([walletAddress])
  @@index([status])
}

model SourceOfFundsDeclaration {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Declaration fields
  primarySource     String    // Employment, Investment, Inheritance, etc.
  secondarySources  String[]
  employerName      String?
  occupation        String?
  estimatedNetWorth String?   // Range selection
  expectedTradingVolume String? // Range selection

  // Supporting documentation (optional)
  hasDocumentation  Boolean   @default(false)
  documentationNotes String?

  // Sign-off
  declarationText   String
  signatureHash     String
  signedAt          DateTime
  ipAddress         String

  // Review
  isApproved        Boolean   @default(false)
  reviewNotes       String?
  reviewedAt        DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model RiskAcknowledgment {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Individual acknowledgments
  acknowledgesVolatility       Boolean @default(false)
  acknowledgesLiquidityRisk    Boolean @default(false)
  acknowledgesRegulatoryRisk   Boolean @default(false)
  acknowledgesNoInsurance      Boolean @default(false)
  acknowledgesLossRisk         Boolean @default(false)
  acknowledgesExperimental     Boolean @default(false)
  acknowledgesRegSCompliance   Boolean @default(false)
  acknowledgesTransferRestrictions Boolean @default(false)

  // Full acknowledgment document
  documentVersion   String    // Version of the acknowledgment document
  documentHash      String    // Hash of the document for integrity

  // Sign-off
  signatureHash     String
  signedAt          DateTime
  ipAddress         String

  createdAt         DateTime  @default(now())
}

model CompliancePeriod {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 40-day compliance period for Reg S
  periodStartDate   DateTime
  periodEndDate     DateTime
  periodDays        Int       @default(40)

  // Status
  isActive          Boolean   @default(true)
  isCompleted       Boolean   @default(false)
  completedAt       DateTime?

  // User acknowledgment of the period
  acknowledgedAt    DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([periodEndDate])
  @@index([isActive])
}

model AuditLog {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  action            AuditAction
  details           String?     // JSON string with additional context
  ipAddress         String?
  userAgent         String?

  // Reference to related entity
  entityType        String?     // GeoVerification, KycVerification, etc.
  entityId          String?

  // Immutability (hash of previous log for chain integrity)
  previousLogHash   String?
  logHash           String

  createdAt         DateTime    @default(now())

  // Audit logs are immutable - no updatedAt

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model BlockedRegion {
  id                String    @id @default(cuid())
  countryCode       String    @unique
  countryName       String
  reason            String    // US_INVESTOR, SANCTIONED, etc.
  isActive          Boolean   @default(true)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([countryCode])
  @@index([isActive])
}

model SumsubWebhook {
  id                String    @id @default(cuid())

  // Webhook data
  webhookId         String    @unique
  applicantId       String
  eventType         String
  reviewStatus      String?
  reviewResult      String?   // JSON string

  // Raw payload (encrypted)
  rawPayload        String
  signatureValid    Boolean

  // Processing
  processedAt       DateTime?
  processingError   String?

  receivedAt        DateTime  @default(now())

  @@index([applicantId])
  @@index([eventType])
  @@index([receivedAt])
}

// ============================================
// PRIVATE COMPANY MODELS (Migrated from Railway)
// ============================================

model PrivateCompany {
  id                          Int               @id
  name                        String            @unique
  industry                    String
  description                 String
  website                     String

  // Valuation data - BigInt for trillion-dollar valuations
  valuationUsd                BigInt
  valuationAsOf               DateTime
  totalFundingUsd             BigInt

  // Latest funding round info
  lastFundingRoundType        String
  lastFundingDate             DateTime
  lastFundingEstPricePerShareUsd Decimal?       @db.Decimal(20, 4)

  // Company info
  employees                   Int
  ceo                         String

  // Relations
  products                    CompanyProduct[]
  fundingHistory              FundingRound[]

  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt

  @@index([industry])
  @@index([valuationUsd])
}

model CompanyProduct {
  id                String          @id @default(cuid())
  companyId         Int
  company           PrivateCompany  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name              String
  description       String

  createdAt         DateTime        @default(now())

  @@index([companyId])
}

model FundingRound {
  id                        String          @id @default(cuid())
  companyId                 Int
  company                   PrivateCompany  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  roundNumber               Int?
  type                      String
  date                      DateTime
  amountRaisedUsd           BigInt?
  amountRaisedNote          String?
  preMoneyValuationUsd      BigInt?
  postMoneyValuationUsd     BigInt?
  pricePerShareUsd          Decimal?        @db.Decimal(20, 4)

  createdAt                 DateTime        @default(now())

  @@index([companyId])
  @@index([date])
}

// ============================================
// TRADING WALLET MODELS (Polymarket-style)
// ============================================

model TradingWallet {
  id                String              @id @default(cuid())
  userId            String              @unique
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Privy wallet identifiers
  privyWalletId     String              @unique
  address           String              @unique
  chainId           Int                 @default(137) // Polygon

  // Status
  status            TradingWalletStatus @default(PENDING_CREATION)

  // Privy policy association (for transaction limits)
  policyId          String?

  // Server signer for delegated actions
  hasServerSigner   Boolean             @default(false)
  serverSignerId    String?

  // Relations
  deposits           Deposit[]
  withdrawals        Withdrawal[]
  etfOrders          EtfOrder[]
  etfPositions       EtfPosition[]
  cachedTransactions CachedTransaction[]
  syncState          WalletSyncState?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([address])
  @@index([status])
}

model Deposit {
  id                String              @id @default(cuid())
  tradingWalletId   String
  tradingWallet     TradingWallet       @relation(fields: [tradingWalletId], references: [id], onDelete: Cascade)

  // Transaction details
  fromAddress       String
  tokenAddress      String
  amount            Decimal             @db.Decimal(78, 0) // Support full uint256 range
  amountUsd         Decimal?            @db.Decimal(20, 2)
  txHash            String?             @unique
  chainId           Int

  // Confirmation tracking
  status            DepositStatus       @default(PENDING)
  confirmations     Int                 @default(0)
  requiredConfirmations Int             @default(64)

  // Compliance screening
  screenedAt        DateTime?
  screeningPassed   Boolean?
  screeningDetails  String?             // JSON with screening results

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  confirmedAt       DateTime?

  @@index([tradingWalletId])
  @@index([txHash])
  @@index([status])
  @@index([fromAddress])
}

model Withdrawal {
  id                String              @id @default(cuid())
  tradingWalletId   String
  tradingWallet     TradingWallet       @relation(fields: [tradingWalletId], references: [id], onDelete: Cascade)

  // Transaction details
  toAddress         String
  tokenAddress      String
  amount            Decimal             @db.Decimal(78, 0) // Support full uint256 range
  amountUsd         Decimal?            @db.Decimal(20, 2)
  txHash            String?             @unique
  chainId           Int

  // Status
  status            WithdrawalStatus    @default(PENDING_APPROVAL)

  // MFA requirement
  requiresMfa       Boolean             @default(false)
  mfaCompletedAt    DateTime?

  // Approval tracking
  approvedAt        DateTime?
  approvedBy        String?             // System or admin ID
  rejectedAt        DateTime?
  rejectionReason   String?

  // Execution
  executedAt        DateTime?
  executionError    String?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([tradingWalletId])
  @@index([txHash])
  @@index([status])
  @@index([toAddress])
}

// ============================================
// ETF TRADING MODELS (Alpaca Integration)
// ============================================

model EtfOrder {
  id                String          @id @default(cuid())
  tradingWalletId   String
  tradingWallet     TradingWallet   @relation(fields: [tradingWalletId], references: [id], onDelete: Cascade)

  // Alpaca identifiers
  alpacaOrderId     String?         @unique
  clientOrderId     String          @unique @default(cuid())

  // Order details
  symbol            String          // "RVI" or "VCX"
  side              String          // "BUY" or "SELL"
  type              String          // "MARKET" or "LIMIT"
  notionalUsd       Decimal?        @db.Decimal(20, 2) // Dollar amount
  qty               Decimal?        @db.Decimal(20, 8) // Share quantity
  limitPrice        Decimal?        @db.Decimal(20, 4) // For limit orders

  // Fill information
  filledQty         Decimal         @default(0) @db.Decimal(20, 8)
  filledAvgPrice    Decimal?        @db.Decimal(20, 4)

  // Status tracking
  status            EtfOrderStatus  @default(PENDING)
  statusMessage     String?

  // Timestamps
  createdAt         DateTime        @default(now())
  submittedAt       DateTime?
  filledAt          DateTime?

  @@index([tradingWalletId])
  @@index([alpacaOrderId])
  @@index([symbol])
  @@index([status])
  @@index([createdAt])
}

model EtfPosition {
  id                String          @id @default(cuid())
  tradingWalletId   String
  tradingWallet     TradingWallet   @relation(fields: [tradingWalletId], references: [id], onDelete: Cascade)

  // Position details
  symbol            String          // "RVI" or "VCX"
  qty               Decimal         @db.Decimal(20, 8)
  costBasis         Decimal         @db.Decimal(20, 2) // Total cost
  avgEntryPrice     Decimal         @db.Decimal(20, 4)

  // Current valuation (updated periodically)
  currentPrice      Decimal?        @db.Decimal(20, 4)
  marketValue       Decimal?        @db.Decimal(20, 2)
  unrealizedPl      Decimal?        @db.Decimal(20, 2)

  lastSyncedAt      DateTime?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([tradingWalletId, symbol])
  @@index([tradingWalletId])
  @@index([symbol])
}

// ============================================
// TRANSACTION CACHING (Performance Optimization)
// ============================================

model CachedTransaction {
  id                  String        @id @default(cuid())
  tradingWalletId     String
  tradingWallet       TradingWallet @relation(fields: [tradingWalletId], references: [id], onDelete: Cascade)

  txHash              String
  type                String        // "deposit" | "withdrawal"
  asset               String        // "USDC" | "USDC.e" | "MATIC" | etc.
  amount              Decimal       @db.Decimal(78, 0)
  amountFormatted     Float         // Human-readable amount
  fromAddress         String
  toAddress           String
  counterpartyAddress String
  blockTimestamp      DateTime
  chainId             Int           @default(137)
  syncedAt            DateTime      @default(now())

  @@unique([tradingWalletId, txHash, type])
  @@index([tradingWalletId])
  @@index([blockTimestamp])
}

model WalletSyncState {
  id                String        @id @default(cuid())
  tradingWalletId   String        @unique
  tradingWallet     TradingWallet @relation(fields: [tradingWalletId], references: [id], onDelete: Cascade)

  lastSyncedAt      DateTime?
  isSyncing         Boolean       @default(false)
  syncError         String?
  transactionCount  Int           @default(0)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}
