{
  "name": "@vaulto/bridge-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for PreStock Token Bridge (Solana ↔ Polygon)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "verify-supply": "tsx src/monitoring/cli.ts"
  },
  "dependencies": {
    "@wormhole-foundation/sdk": "^1.0.0",
    "@wormhole-foundation/sdk-evm": "^1.0.0",
    "@wormhole-foundation/sdk-solana": "^1.0.0",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "viem": "^2.47.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
